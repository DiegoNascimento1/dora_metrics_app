# ---- Postgres ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dora
POSTGRES_USER=dora
POSTGRES_PASSWORD=dora
POSTGRES_SSLMODE=disable

# Pool
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# ---- API ----
API_HTTP_ADDR=:8080
API_LOG_LEVEL=info
API_ENV=development

# ---- Worker ----
WORKER_CONCURRENCY=10
WORKER_REDIS_ADDR=localhost:6379
# Endereço HTTP onde o worker expõe /metrics (Prometheus scrape)
WORKER_METRICS_ADDR=:9090

# ---- Secret provider ----
# env | vault | aws-secrets-manager
SECRET_PROVIDER=env

# ---- GitLab ----
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=

# Webhook shared secret (configurar igual no GitLab)
GITLAB_WEBHOOK_TOKEN=change-me-in-prod

# ---- Jira / Atlassian ----
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# MCP endpoint (default oficial Atlassian)
JIRA_MCP_URL=https://mcp.atlassian.com/v1/mcp
JIRA_MCP_AUTH_KIND=api_token

# Webhook shared secret
JIRA_WEBHOOK_SECRET=change-me-in-prod

# ---- IA / LLM ----
# Chave Anthropic para geração de narrativas em explainTrend.
# Sem essa chave, o servidor usa o template determinístico como fallback.
ANTHROPIC_API_KEY=sk-ant-...

# ---- SSE (Server-Sent Events) ----
# Prefixo do canal Redis para notificações de métricas em tempo real.
REDIS_SSE_CHANNEL_PREFIX=metrics

# ---- GitHub ----
# Token de acesso GitHub (PAT ou GitHub App token) para coleta de deployments/PRs.
GITHUB_TOKEN=

# Webhook secret compartilhado com o GitHub (configurar igual no GitHub Settings).
GITHUB_WEBHOOK_SECRET=change-me-in-prod

# ---- Frontend (consumido em build-time) ----
NG_APP_API_BASE_URL=http://localhost:8080
